{
  "name": "Samsung AC Control",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [3000],
  "postCreateCommand": "npm install",
  "start": {
    "cmd": "npm start"
  }
}